.page { min-height: 100vh; padding-bottom: 100rpx; }

/* 轮播图 */
.case-swiper {
  width: 100%;
  height: 560rpx;
}
.swiper-img { width: 100%; height: 100%; }
.img-counter {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  z-index: 10;
}

/* 内容区 */
.detail-content { padding-top: 40rpx; }
.detail-header { margin-bottom: 32rpx; }
.detail-tags { margin-bottom: 16rpx; }
.detail-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}
.meta-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

/* 描述 */
.detail-desc { margin-bottom: 48rpx; }
.desc-label {
  display: block;
  font-size: 22rpx;
  color: #2563eb;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}
.desc-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.8;
}

/* 操作区 */
.detail-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 48rpx;
}
.detail-actions button {
  flex: 1;
  font-size: 28rpx;
  padding: 22rpx 0;
}
