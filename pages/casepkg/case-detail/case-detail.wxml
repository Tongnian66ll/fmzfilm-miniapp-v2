<view class="page" wx:if="{{!loading && caseItem}}">
  <!-- 图片轮播 -->
  <swiper class="case-swiper" autoplay circular indicator-dots indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#2563eb" bindchange="swiperChange">
    <swiper-item wx:for="{{caseItem.images}}" wx:key="*this" bindtap="previewImage" data-url="{{item}}">
      <image class="swiper-img" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>
  <view class="img-counter" wx:if="{{caseItem.images.length > 1}}">
    {{currentImageIndex + 1}} / {{caseItem.images.length}}
  </view>

  <!-- 内容区 -->
  <view class="detail-content container">
    <view class="detail-header">
      <view class="detail-tags">
        <text class="tag" wx:for="{{caseItem.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
      </view>
      <text class="detail-title">{{caseItem.title}}</text>
      <view class="detail-meta">
        <text class="meta-item">年份：{{caseItem.year}}</text>
        <text class="meta-item">时长：{{caseItem.duration}}</text>
        <text class="meta-item" wx:if="{{caseItem.role}}">职责：{{caseItem.role}}</text>
      </view>
    </view>

    <view class="divider"></view>

    <view class="detail-desc">
      <text class="desc-label">项目简介</text>
      <text class="desc-text">{{caseItem.description}}</text>
    </view>

    <!-- 操作区 -->
    <view class="detail-actions">
      <button class="btn-primary" open-type="contact">联系我们</button>
      <button class="btn-outline" open-type="share">分享给朋友</button>
    </view>
  </view>
</view>

<view class="loading-wrap" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
