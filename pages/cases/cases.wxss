/* 分类筛选 */
.category-scroll {
  display: flex;
  white-space: nowrap;
  margin: 0 -32rpx 40rpx;
  padding: 0 32rpx;
}
.category-tag {
  display: inline-block;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.category-tag.active {
  color: #ffffff;
  background: rgba(37,99,235,0.3);
  border-color: #2563eb;
}

/* 案例卡片 */
.case-card {
  display: flex;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.case-img-wrap {
  width: 260rpx;
  min-height: 200rpx;
  flex-shrink: 0;
  background: #1a1a2e;
}
.case-img { width: 100%; height: 100%; }
.case-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}
.case-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 10rpx;
}
.case-meta {
  display: flex;
  gap: 20rpx;
  margin-top: auto;
}
.case-year, .case-duration {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

/* 底部更多案例提示 */
.more-hint {
  padding: 60rpx 40rpx 80rpx;
  text-align: center;
}
.hint-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  line-height: 1.6;
}
