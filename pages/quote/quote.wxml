<view class="page container">
  <view class="section-header">
    <text class="section-overline">PRICE LIST</text>
    <text class="section-title">服务报价</text>
    <text class="section-desc">选择服务类型，获取预估费用</text>
  </view>

  <!-- 服务列表 -->
  <view class="service-list">
    <view
      class="service-item {{selectedService.id === item.id ? 'selected' : ''}}"
      wx:for="{{services}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="selectService"
    >
      <view class="service-left">
        <text class="service-icon">{{item.icon}}</text>
        <view class="service-text">
          <text class="service-name">{{item.name}}</text>
          <text class="service-desc">{{item.description}}</text>
          <text class="service-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
      </view>
      <view class="service-right">
        <text class="service-price">{{item.priceLabel}}</text>
        <text class="service-unit">/{{item.unitLabel}}</text>
      </view>
    </view>
  </view>

  <!-- 选中后的详细配置 -->
  <view class="config-section" wx:if="{{selectedService}}">
    <view class="divider"></view>

    <!-- ========== 时长输入（宣传片/TVC/短片） ========== -->
    <view class="quantity-section" wx:if="{{selectedService.configType === 'duration'}}">
      <text class="field-label">{{selectedService.durationLabel}}</text>
      <view class="quantity-control">
        <view class="qty-btn" bindtap="durationMinus">−</view>
        <input class="qty-input" type="number" value="{{duration}}" bindinput="durationChange" />
        <view class="qty-btn" bindtap="durationAdd">+</view>
        <text class="qty-suffix">{{selectedService.durationUnit}}</text>
      </view>
    </view>

    <!-- ========== 套餐选择 + 月数（短视频代运营） ========== -->
    <block wx:if="{{selectedService.configType === 'plan'}}">
      <view class="quantity-section">
        <text class="field-label">选择套餐</text>
        <view class="plan-options">
          <view
            class="plan-option {{selectedPlan === item.id ? 'selected' : ''}}"
            wx:for="{{selectedService.plans}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="selectPlan"
          >
            <view class="plan-header">
              <text class="plan-name">{{item.name}}</text>
              <text class="plan-price">¥{{item.price}}<text class="plan-unit">/{{item.unit}}</text></text>
            </view>
            <text class="plan-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
      <view class="quantity-section">
        <text class="field-label">订购月数</text>
        <view class="quantity-control">
          <view class="qty-btn" bindtap="quantityMinus">−</view>
          <input class="qty-input" type="number" value="{{quantity}}" bindinput="quantityChange" />
          <view class="qty-btn" bindtap="quantityAdd">+</view>
          <text class="qty-suffix">个月</text>
        </view>
      </view>
    </block>

    <!-- ========== 时长切换（活动纪录） ========== -->
    <view class="quantity-section" wx:if="{{selectedService.configType === 'durationToggle'}}">
      <text class="field-label">选择时长</text>
      <view class="duration-options">
        <view
          class="duration-option {{eventDurationType === item.id ? 'selected' : ''}}"
          wx:for="{{selectedService.durationOptions}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="selectEventDuration"
        >
          <text class="duration-name">{{item.name}}</text>
          <text class="duration-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>

    <!-- ========== 附加服务 ========== -->
    <view class="addons-section">
      <text class="field-label">附加服务（可选）</text>
      <view class="addons-list">
        <view wx:for="{{currentAddons}}" wx:key="id">
          <view
            class="addon-item {{selectedAddons.indexOf(item.id) > -1 ? 'selected' : ''}}"
            data-id="{{item.id}}"
            bindtap="toggleAddon"
          >
            <view class="addon-check">{{selectedAddons.indexOf(item.id) > -1 ? '✓' : ''}}</view>
            <view class="addon-info">
              <text class="addon-name">{{item.name}}</text>
              <text class="addon-price" wx:if="{{item.pricingType === 'custom'}}">{{item.note || '费用另算'}}</text>
              <text class="addon-price" wx:elif="{{item.pricingType === 'threshold'}}">{{item.note}}</text>
              <text class="addon-price" wx:else>+¥{{item.price}}/{{item.unit}}</text>
            </view>
          </view>
          <!-- 需要数量输入的附加服务 -->
          <view class="addon-qty-row" wx:if="{{selectedAddons.indexOf(item.id) > -1 && (item.pricingType === 'perAddonQty' || item.pricingType === 'threshold')}}">
            <text class="addon-qty-label">{{item.pricingType === 'threshold' ? item.name + '数量（' + item.unit + '）' : '数量（' + item.unit + '）'}}</text>
            <view class="qty-control-sm">
              <view class="qty-btn-sm" data-id="{{item.id}}" catchtap="addonQtyMinus">−</view>
              <input class="qty-input-sm" type="number" value="{{addonQuantities[item.id] || 0}}" data-id="{{item.id}}" catchtap="" bindinput="addonQtyChange" />
              <view class="qty-btn-sm" data-id="{{item.id}}" catchtap="addonQtyAdd">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 报价结果 ========== -->
    <view class="quote-result" wx:if="{{totalPrice > 0 || priceBreakdown.length > 0}}">
      <view class="divider"></view>
      <view class="breakdown">
        <view class="breakdown-item" wx:for="{{priceBreakdown}}" wx:key="label">
          <view class="breakdown-left">
            <text class="breakdown-label">{{item.label}}</text>
            <text class="breakdown-detail">{{item.detail}}</text>
          </view>
          <text class="breakdown-amount" wx:if="{{item.amount > 0}}">¥{{item.amount}}</text>
          <text class="breakdown-amount breakdown-custom" wx:else>另算</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="total-row">
        <text class="total-label">预估总价</text>
        <text class="total-price">¥{{totalPrice}}</text>
      </view>
      <view class="quote-actions">
        <button class="btn-primary" bindtap="showWechatQR">微信咨询</button>
      </view>
    </view>
  </view>

  <!-- 微信二维码弹窗 -->
  <view class="qr-mask" wx:if="{{showWechatQR}}" catchtap="closeWechatQR">
    <view class="qr-popup" catchtap="">
      <image class="qr-image" src="/images/wechat-qr.jpg" mode="aspectFit" />
      <text class="qr-tip">长按识别图中二维码添加微信</text>
      <text class="qr-wechat">微信号：njfmz1</text>
      <text class="qr-close" catchtap="closeWechatQR">✕</text>
    </view>
  </view>
</view>
