.section-desc { display: block; font-size: 26rpx; color: rgba(255,255,255,0.5); margin-top: 8rpx; }

.service-list { margin-bottom: 20rpx; }
.service-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 24rpx; background: rgba(255,255,255,0.03);
  border: 2rpx solid rgba(255,255,255,0.06); border-radius: 16rpx;
  margin-bottom: 16rpx; transition: all 0.3s;
}
.service-item.selected { border-color: #2563eb; background: rgba(37,99,235,0.08); }
.service-left { display: flex; align-items: center; flex: 1; }
.service-icon { font-size: 44rpx; margin-right: 20rpx; }
.service-text { flex: 1; }
.service-name { display: block; font-size: 30rpx; color: #fff; font-weight: 500; }
.service-desc { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 6rpx; }
.service-note { font-size: 22rpx; color: #999; margin-top: 8rpx; line-height: 1.4; }
.service-right { text-align: right; flex-shrink: 0; margin-left: 20rpx; }
.service-price { display: block; font-size: 36rpx; color: #2563eb; font-weight: 700; }
.service-unit { display: block; font-size: 22rpx; color: rgba(255,255,255,0.35); margin-top: 4rpx; }

.config-section { margin-top: 20rpx; }
.quantity-section { margin-bottom: 32rpx; }
.field-label { display: block; font-size: 26rpx; color: rgba(255,255,255,0.6); margin-bottom: 16rpx; }
.quantity-control { display: flex; align-items: center; }
.qty-btn { width: 80rpx; height: 72rpx; background: rgba(255,255,255,0.08); border-radius: 12rpx; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 36rpx; }
.qty-input { width: 120rpx; height: 72rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 12rpx; text-align: center; color: #fff; font-size: 30rpx; margin: 0 12rpx; }
.qty-suffix { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-left: 12rpx; }

.addons-section { margin-bottom: 32rpx; }
.addon-item { display: flex; align-items: center; padding: 22rpx 20rpx; background: rgba(255,255,255,0.03); border: 1rpx solid rgba(255,255,255,0.06); border-radius: 12rpx; margin-bottom: 12rpx; }
.addon-item.selected { border-color: #2563eb; background: rgba(37,99,235,0.08); }
.addon-check { width: 44rpx; height: 44rpx; border: 2rpx solid rgba(255,255,255,0.2); border-radius: 8rpx; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; font-size: 24rpx; color: #2563eb; }
.addon-item.selected .addon-check { border-color: #2563eb; background: rgba(37,99,235,0.2); }
.addon-info { flex: 1; }
.addon-name { display: block; font-size: 28rpx; color: #fff; }
.addon-price { display: block; font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 4rpx; }

.addon-qty-row { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 20rpx 12rpx 64rpx; margin-bottom: 8rpx; }
.addon-qty-label { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.qty-control-sm { display: flex; align-items: center; }
.qty-btn-sm { width: 56rpx; height: 48rpx; background: rgba(255,255,255,0.08); border-radius: 8rpx; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 28rpx; }
.qty-input-sm { width: 80rpx; height: 48rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 8rpx; text-align: center; color: #fff; font-size: 24rpx; margin: 0 8rpx; }

.plan-options { display: flex; flex-direction: column; gap: 12rpx; }
.plan-option { padding: 22rpx 20rpx; background: rgba(255,255,255,0.03); border: 2rpx solid rgba(255,255,255,0.06); border-radius: 12rpx; transition: all 0.3s; }
.plan-option.selected { border-color: #2563eb; background: rgba(37,99,235,0.08); }
.plan-header { display: flex; justify-content: space-between; align-items: center; }
.plan-name { font-size: 28rpx; color: #fff; font-weight: 500; }
.plan-price { font-size: 32rpx; color: #2563eb; font-weight: 700; }
.plan-unit { font-size: 22rpx; color: rgba(255,255,255,0.4); font-weight: 400; }
.plan-desc { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 8rpx; }

.duration-options { display: flex; gap: 16rpx; }
.duration-option { flex: 1; padding: 22rpx 20rpx; background: rgba(255,255,255,0.03); border: 2rpx solid rgba(255,255,255,0.06); border-radius: 12rpx; text-align: center; transition: all 0.3s; }
.duration-option.selected { border-color: #2563eb; background: rgba(37,99,235,0.08); }
.duration-name { display: block; font-size: 28rpx; color: #fff; font-weight: 500; }
.duration-price { display: block; font-size: 32rpx; color: #2563eb; font-weight: 700; margin-top: 6rpx; }

.quote-result { margin-top: 20rpx; }
.breakdown-item { display: flex; justify-content: space-between; align-items: center; padding: 14rpx 0; }
.breakdown-left { flex: 1; }
.breakdown-label { display: block; font-size: 28rpx; color: #fff; }
.breakdown-detail { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); }
.breakdown-amount { font-size: 28rpx; color: rgba(255,255,255,0.7); }
.breakdown-custom { color: rgba(255,255,255,0.35); font-style: italic; }

.total-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; }
.total-label { font-size: 30rpx; color: #fff; font-weight: 500; }
.total-price { font-size: 48rpx; color: #2563eb; font-weight: 700; }

.quote-actions { display: flex; gap: 20rpx; margin-top: 40rpx; }
.quote-actions button { flex: 1; font-size: 28rpx; }

/* QR弹窗 */
.qr-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 999; }
.qr-popup { width: 600rpx; background: #1a1a2e; border-radius: 24rpx; padding: 48rpx 40rpx; text-align: center; border: 1rpx solid rgba(37,99,235,0.3); }
.qr-image { width: 400rpx; height: 400rpx; border-radius: 16rpx; margin: 0 auto 24rpx; display: block; }
.qr-tip { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); margin-bottom: 12rpx; }
.qr-wechat { display: block; font-size: 26rpx; color: #fff; font-weight: 600; }
.qr-close { position: absolute; top: 20rpx; right: 24rpx; font-size: 32rpx; color: rgba(255,255,255,0.5); padding: 8rpx; }
