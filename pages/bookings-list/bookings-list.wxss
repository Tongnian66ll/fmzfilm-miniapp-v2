.page { padding-bottom: 60rpx; }
.section-header { padding: 40rpx 32rpx 20rpx; }
.section-overline { font-size: 24rpx; color: #5b7fff; letter-spacing: 4rpx; display: block; margin-bottom: 8rpx; }
.section-title { font-size: 44rpx; font-weight: 700; color: #fff; display: block; }

.booking-list { padding: 0 32rpx; }
.booking-card {
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.booking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(91,127,255,0.08);
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.booking-service { font-size: 32rpx; font-weight: 600; color: #fff; }
.booking-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255,180,0,0.15);
  color: #ffb400;
}
.status-confirmed { background: rgba(82,196,26,0.15); color: #52c41a; }
.status-completed { background: rgba(91,127,255,0.15); color: #5b7fff; }

.booking-body { padding: 20rpx 28rpx; }
.booking-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}
.info-label { font-size: 26rpx; color: #999; }
.info-value { font-size: 26rpx; color: #ddd; }
.info-value.price { color: #5b7fff; font-weight: 600; }

.booking-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 28rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.booking-time { font-size: 22rpx; color: #666; }
.btn-contact {
  font-size: 24rpx;
  background: transparent;
  color: #5b7fff;
  border: 1rpx solid #5b7fff;
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
  line-height: 1.6;
}
.btn-contact::after { border: none; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-bottom: 40rpx; }
.btn-primary {
  background: #5b7fff;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0 60rpx;
  height: 72rpx;
  line-height: 72rpx;
}
.btn-primary::after { border: none; }
