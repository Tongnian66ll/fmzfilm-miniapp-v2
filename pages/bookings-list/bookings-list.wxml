<view class="page container">
  <view class="section-header">
    <text class="section-overline">MY BOOKINGS</text>
    <text class="section-title">我的预约</text>
  </view>

  <view class="booking-list" wx:if="{{bookings.length > 0}}">
    <view class="booking-card" wx:for="{{bookings}}" wx:key="_id">
      <view class="booking-header">
        <text class="booking-service">{{item.serviceType}}</text>
        <text class="booking-status status-{{item.status}}">{{item.status === 'pending' ? '待确认' : item.status === 'confirmed' ? '已确认' : item.status === 'completed' ? '已完成' : item.status}}</text>
      </view>
      <view class="booking-body">
        <view class="booking-info">
          <text class="info-label">联系人</text>
          <text class="info-value">{{item.name}}</text>
        </view>
        <view class="booking-info">
          <text class="info-label">电话</text>
          <text class="info-value">{{item.phone}}</text>
        </view>
        <view class="booking-info" wx:if="{{item.budget}}">
          <text class="info-label">预算</text>
          <text class="info-value">{{item.budget}}</text>
        </view>
        <view class="booking-info" wx:if="{{item.estimatedPrice}}">
          <text class="info-label">预估报价</text>
          <text class="info-value price">¥{{item.estimatedPrice}}</text>
        </view>
        <view class="booking-info" wx:if="{{item.description}}">
          <text class="info-label">需求描述</text>
          <text class="info-value">{{item.description}}</text>
        </view>
      </view>
      <view class="booking-footer">
        <text class="booking-time">{{item.createTimeStr}}</text>
        <view class="booking-actions">
          <button class="btn-contact" open-type="contact">联系客服</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无预约记录</text>
    <button class="btn-primary" bindtap="goHome">去预约咨询</button>
  </view>
</view>
