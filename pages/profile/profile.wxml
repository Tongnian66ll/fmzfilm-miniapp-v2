<view class="container">
  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="avatar-wrap" bindtap="getUserProfile">
      <image wx:if="{{userInfo}}" class="avatar" src="{{userInfo.avatarUrl}}" />
      <view wx:else class="avatar-default">
        <text class="avatar-icon">👤</text>
      </view>
    </view>
    <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <block wx:for="{{menuItems}}" wx:key="id">
      <!-- 分享项使用 button open-type="share" -->
      <button wx:if="{{item.type === 'share'}}" class="menu-item share-btn" open-type="share">
        <view class="menu-left">
          <text class="menu-icon">{{item.icon}}</text>
          <text class="menu-label">{{item.label}}</text>
        </view>
        <view class="menu-right">
          <text class="menu-arrow">›</text>
        </view>
      </button>
      <!-- 普通菜单项 -->
      <view wx:else class="menu-item" bindtap="onMenuTap" data-id="{{item.id}}">
        <view class="menu-left">
          <text class="menu-icon">{{item.icon}}</text>
          <text class="menu-label">{{item.label}}</text>
        </view>
        <view class="menu-right">
          <text wx:if="{{item.desc}}" class="menu-desc">{{item.desc}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部信息 -->
  <view class="footer-info">
    <text class="footer-text">© 2026 分秒帧影视</text>
    <text class="footer-ver" catchtap="onVersionTap">v1.0</text>
  </view>

  <!-- 微信二维码弹窗 -->
  <view class="qr-mask" wx:if="{{showWechatQR}}" catchtap="closeWechatQR">
    <view class="qr-popup" catchtap="">
      <image class="qr-image" src="/images/wechat-qr.jpg" mode="aspectFit" />
      <text class="qr-tip">长按识别图中二维码添加微信</text>
      <text class="qr-wechat">微信号：njfmz1</text>
      <text class="qr-close" catchtap="closeWechatQR">✕</text>
    </view>
  </view>
</view>
