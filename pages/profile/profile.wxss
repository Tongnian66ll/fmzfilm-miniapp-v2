.page { min-height: 100vh; background: #0a0a0f; padding: 24rpx; }

.user-section {
  display: flex;
  align-items: center;
  padding: 40rpx 0;
}
.avatar-wrap { margin-right: 28rpx; }
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(37,99,235,0.5);
}
.user-name { display: block; font-size: 36rpx; font-weight: 600; color: #fff; }

.menu-list {
  margin-top: 16rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 16rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.menu-item:last-child { border-bottom: none; }
.menu-left {
  display: flex;
  align-items: center;
}
.menu-icon { font-size: 40rpx; margin-right: 24rpx; }
.menu-label { font-size: 30rpx; color: #fff; }
.menu-right {
  display: flex;
  align-items: center;
}
.menu-desc { font-size: 22rpx; color: rgba(255,255,255,0.4); margin-right: 12rpx; }
.menu-arrow { font-size: 32rpx; color: rgba(255,255,255,0.3); }

/* 分享按钮重置样式，与普通菜单项一致 */
.share-btn {
  /* 重置 button 默认样式 */
  background: transparent !important;
  border: none !important;
  border-radius: 0 !important;
  margin: 0 !important;
  line-height: inherit !important;
  text-align: left !important;
  color: inherit !important;
  font-size: inherit !important;
  padding: 32rpx 28rpx !important;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.share-btn::after {
  display: none !important;
}
.share-btn:active {
  background: rgba(255,255,255,0.05) !important;
}

.footer-info {
  text-align: center;
  padding: 80rpx 0 40rpx;
}
.footer-text { display: block; font-size: 22rpx; color: rgba(255,255,255,0.2); margin-bottom: 12rpx; }
.footer-ver { display: block; font-size: 20rpx; color: rgba(255,255,255,0.08); }

.qr-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.qr-popup {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  border: 1rpx solid rgba(37,99,235,0.3);
}
.qr-image {
  width: 400rpx; height: 400rpx;
  border-radius: 16rpx;
  margin: 0 auto 24rpx;
  display: block;
}
.qr-tip { display: block; font-size: 22rpx; color: rgba(255,255,255,0.4); margin-bottom: 12rpx; }
.qr-wechat { display: block; font-size: 26rpx; color: #fff; font-weight: 600; }
.qr-close {
  position: absolute;
  top: 20rpx; right: 24rpx;
  font-size: 32rpx; color: rgba(255,255,255,0.5);
  padding: 8rpx;
}
